{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../out-tsc/app-e2e", // Updated outDir from "e2e" to "app-e2e" to match Angular 11 conventions
    "module": "commonjs",
    "target": "es6", // Updated from "es5" to "es6" for better compatibility with Angular 11
    "types": [
      "jasmine",
      "node"
    ]
    // Removed "jasminewd2" from types as it's no longer needed in Angular 11
  }
}